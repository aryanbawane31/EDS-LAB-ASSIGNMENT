import pandas as pd

# Prompt the user for the file name
file_name = input()

# Load the data into a Pandas DataFrame
df = pd.read_csv(file_name, sep="\s+", names=["Name", "Age", "Grade"])

# Display the first five rows
print("First five rows:")
print(df.head())

# Calculate the average age of students (limited to 2 decimal places)
average_age = round(df["Age"].mean(), 2)
print(f"Average age: {average_age}")

# Filter students with a grade up to B
filtered_students = df[df["Grade"] <= "B"]
print("Students with a grade up to B")
print(filtered_students)


